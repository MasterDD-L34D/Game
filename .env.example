# Variabili ambiente per lo stack locale/CI
DATABASE_URL=postgresql://game:game@localhost:5432/game?schema=public
PRISMA_BOOTSTRAP_FILE=.docker-prisma-bootstrapped
POSTGRES_USER=game
POSTGRES_PASSWORD=game
POSTGRES_DB=game

# Generation orchestrator worker pool autoclose.
#
# Default OFF (vuoto/null) -> il pool worker Python resta in vita per tutta
# la durata del backend. Questo e' il valore corretto per `npm run start:api`
# e per qualunque uso "live" del backend (smoke test manuale, dev locale,
# prod). NON settarlo a un numero piccolo in dev: il primo POST verso
# /api/v1/generation/species spawnera' un worker, dopo l'idle il pool si
# chiudera' e il prossimo request fallira' con "Pool orchestrator non
# disponibile (issue #1342)".
#
# I test API invece settano esplicitamente ORCHESTRATOR_AUTOCLOSE_MS=2000
# inline (vedi `npm run test:api` e i comandi singoli `node --test ...`)
# perche' i test devono terminare in fretta. NON propagare quel valore
# nel proprio shell di sviluppo.
#
# Valori accettati: numero positivo in millisecondi, oppure
# "off"/"none"/"never"/"disabled"/"0"/vuoto per disabilitare.
ORCHESTRATOR_AUTOCLOSE_MS=
