{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://game.example.com/schemas/evo/accessibility.schema.json",
  "title": "Accessibility Settings",
  "description": "Schema for UI accessibility settings. SoT §18.2 · A2 (open-questions-triage)",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "defaults"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "defaults": { "$ref": "#/$defs/settingsBlock" },
    "presets": {
      "type": "object",
      "patternProperties": {
        "^[a-z0-9_]+$": {
          "type": "object",
          "required": ["label_it", "overrides"],
          "additionalProperties": false,
          "properties": {
            "label_it": { "type": "string", "minLength": 1 },
            "label_en": { "type": "string" },
            "overrides": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "deaf_hoh": { "$ref": "#/$defs/deafHohPartial" },
                "colorblind": { "$ref": "#/$defs/colorblindPartial" },
                "font": { "$ref": "#/$defs/fontPartial" },
                "motion": { "$ref": "#/$defs/motionPartial" },
                "input": { "$ref": "#/$defs/inputPartial" },
                "text": { "$ref": "#/$defs/textPartial" },
                "audio": { "$ref": "#/$defs/audioPartial" }
              }
            }
          }
        }
      }
    },
    "ui_metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "categories": {
          "type": "object",
          "patternProperties": {
            "^[a-z_]+$": {
              "type": "object",
              "required": ["display_it", "order"],
              "additionalProperties": false,
              "properties": {
                "display_it": { "type": "string", "minLength": 1 },
                "display_en": { "type": "string" },
                "order": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "settingsBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deaf_hoh", "colorblind", "font", "motion", "input", "text", "audio"],
      "properties": {
        "deaf_hoh": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "persist_multiplier",
            "flash_enabled",
            "icon_scale",
            "subtitle_all_sfx"
          ],
          "properties": {
            "enabled": { "type": "boolean" },
            "persist_multiplier": { "type": "number", "minimum": 0.5, "maximum": 5.0 },
            "flash_enabled": { "type": "boolean" },
            "icon_scale": { "type": "number", "minimum": 0.5, "maximum": 3.0 },
            "subtitle_all_sfx": { "type": "boolean" }
          }
        },
        "colorblind": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "mode", "pattern_overlay"],
          "properties": {
            "enabled": { "type": "boolean" },
            "mode": {
              "type": "string",
              "enum": ["none", "protanopia", "deuteranopia", "tritanopia", "achromatopsia"]
            },
            "pattern_overlay": { "type": "boolean" }
          }
        },
        "font": {
          "type": "object",
          "additionalProperties": false,
          "required": ["size_multiplier", "dyslexia_friendly"],
          "properties": {
            "size_multiplier": { "type": "number", "minimum": 0.75, "maximum": 2.0 },
            "dyslexia_friendly": { "type": "boolean" }
          }
        },
        "motion": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reduce_animations", "reduce_shake"],
          "properties": {
            "reduce_animations": { "type": "boolean" },
            "reduce_shake": { "type": "boolean" },
            "reduce_flash": { "type": "boolean" }
          }
        },
        "input": {
          "type": "object",
          "additionalProperties": false,
          "required": ["hold_instead_of_mash", "confirm_on_release", "remappable"],
          "properties": {
            "hold_instead_of_mash": { "type": "boolean" },
            "confirm_on_release": { "type": "boolean" },
            "remappable": { "type": "boolean" }
          }
        },
        "text": {
          "type": "object",
          "additionalProperties": false,
          "required": ["auto_advance_delay_ms", "force_manual_advance", "caption_background"],
          "properties": {
            "auto_advance_delay_ms": { "type": "integer", "minimum": 500, "maximum": 20000 },
            "force_manual_advance": { "type": "boolean" },
            "caption_background": { "type": "string", "enum": ["solid", "semi_opaque", "none"] }
          }
        },
        "audio": {
          "type": "object",
          "additionalProperties": false,
          "required": ["master_volume", "music_volume", "sfx_volume", "mute_on_focus_loss"],
          "properties": {
            "master_volume": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "music_volume": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "sfx_volume": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "mute_on_focus_loss": { "type": "boolean" }
          }
        }
      }
    },
    "deafHohPartial": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "persist_multiplier": { "type": "number" },
        "flash_enabled": { "type": "boolean" },
        "icon_scale": { "type": "number" },
        "subtitle_all_sfx": { "type": "boolean" }
      }
    },
    "colorblindPartial": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "mode": {
          "type": "string",
          "enum": ["none", "protanopia", "deuteranopia", "tritanopia", "achromatopsia"]
        },
        "pattern_overlay": { "type": "boolean" }
      }
    },
    "fontPartial": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "size_multiplier": { "type": "number" },
        "dyslexia_friendly": { "type": "boolean" }
      }
    },
    "motionPartial": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reduce_animations": { "type": "boolean" },
        "reduce_shake": { "type": "boolean" },
        "reduce_flash": { "type": "boolean" }
      }
    },
    "inputPartial": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hold_instead_of_mash": { "type": "boolean" },
        "confirm_on_release": { "type": "boolean" },
        "remappable": { "type": "boolean" }
      }
    },
    "textPartial": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "auto_advance_delay_ms": { "type": "integer" },
        "force_manual_advance": { "type": "boolean" },
        "caption_background": { "type": "string", "enum": ["solid", "semi_opaque", "none"] }
      }
    },
    "audioPartial": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "master_volume": { "type": "number" },
        "music_volume": { "type": "number" },
        "sfx_volume": { "type": "number" },
        "mute_on_focus_loss": { "type": "boolean" }
      }
    }
  }
}
