# Force LF line endings for all text files (avoids CRLF/Prettier loop on Windows)
* text=auto eol=lf

# Ensure these are always treated as text with LF
*.js    text eol=lf
*.ts    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.py    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.sh    text eol=lf

# Binary files - no conversion
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
