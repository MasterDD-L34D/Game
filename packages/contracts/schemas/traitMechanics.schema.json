{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.game.local/traitMechanics.schema.json",
  "title": "TraitMechanicsCatalog",
  "type": "object",
  "required": ["schema_version", "traits"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "balance_framework": { "type": "string" },
    "generated_from": { "type": "string" },
    "notes": { "type": "string" },
    "traits": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z0-9_]+$": { "$ref": "#/$defs/mechanics_entry" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "on_hit_status": {
      "type": "object",
      "required": ["name", "dc", "duration_turns"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$",
          "description": "Nome dello status inflitto on-hit."
        },
        "dc": {
          "type": "integer",
          "minimum": 0,
          "description": "CD del saving throw del target."
        },
        "duration_turns": {
          "type": "integer",
          "minimum": 1,
          "description": "Turni di durata dello status."
        }
      },
      "additionalProperties": false,
      "description": "Trigger auto di uno status su attack success."
    },
    "mechanics_entry": {
      "type": "object",
      "required": [
        "trait_code",
        "label",
        "class",
        "tier",
        "attack_mod",
        "defense_mod",
        "damage_step",
        "damage_channel",
        "resistances",
        "on_hit_status",
        "on_hit_stress_delta",
        "note_balance"
      ],
      "properties": {
        "trait_code": {
          "type": "string",
          "pattern": "^TR-\\d+$"
        },
        "label": { "type": "string" },
        "class": {
          "type": "string",
          "enum": ["offensive", "defensive", "hybrid", "mobility", "utility"]
        },
        "tier": {
          "type": "string",
          "enum": ["T1", "T2", "T3", "T4"]
        },
        "attack_mod": { "type": "integer" },
        "defense_mod": { "type": "integer" },
        "damage_step": { "type": "integer", "minimum": 0 },
        "damage_channel": {
          "oneOf": [{ "type": "string", "pattern": "^[a-z0-9_]+$" }, { "type": "null" }]
        },
        "resistances": {
          "type": "object",
          "patternProperties": {
            "^[a-z0-9_]+$": {
              "type": "integer",
              "minimum": -100,
              "maximum": 100
            }
          },
          "additionalProperties": false,
          "description": "Resistenze per canale di danno come oggetto { channel: modifier_pct }."
        },
        "on_hit_status": {
          "oneOf": [{ "$ref": "#/$defs/on_hit_status" }, { "type": "null" }]
        },
        "on_hit_stress_delta": {
          "type": "number",
          "minimum": -1,
          "maximum": 1,
          "description": "Delta di stress (float [-1, 1]) applicato al target su attack success."
        },
        "note_balance": {
          "type": "string",
          "description": "Nota di bilanciamento in italiano."
        }
      },
      "additionalProperties": false
    }
  }
}
