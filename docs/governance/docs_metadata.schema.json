{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://game.local/docs/governance/docs_metadata.schema.json",
  "title": "Game Docs Metadata",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "doc_status",
    "doc_owner",
    "workstream",
    "last_verified",
    "source_of_truth",
    "language",
    "review_cycle_days"
  ],
  "properties": {
    "doc_status": {
      "type": "string",
      "enum": [
        "active",
        "draft",
        "review_needed",
        "legacy_active",
        "generated",
        "historical_ref",
        "superseded"
      ]
    },
    "doc_owner": {
      "type": "string",
      "minLength": 2
    },
    "workstream": {
      "type": "string",
      "enum": [
        "flow",
        "atlas",
        "backend",
        "dataset-pack",
        "ops-qa",
        "incoming",
        "cross-cutting",
        "combat"
      ]
    },
    "last_verified": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "source_of_truth": {
      "type": "boolean"
    },
    "language": {
      "type": "string",
      "enum": ["it", "en", "it-en"]
    },
    "review_cycle_days": {
      "type": "integer",
      "minimum": 1,
      "maximum": 365
    }
  }
}
