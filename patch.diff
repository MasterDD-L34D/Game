+function pickQueueEntry(queue, rng) {
+  const total = queue.reduce((sum, entry) => sum + (entry.score || 1), 0);
+  const threshold = (rng() || Math.random()) * (total || queue.length);
+  let cumulative = 0;
+  let pickedIndex = 0;
+  for (let index = 0; index < queue.length; index += 1) {
+    const weight = queue[index].score || 1;
+    cumulative += weight;
+    if (threshold <= cumulative) {
+      pickedIndex = index;
+      break;
+    }
+  }
+  return queue.splice(pickedIndex, 1)[0];
+}
